# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan
tfplan

# Ignore lock files (for shared modules, comment out if needed)
.terraform.lock.hcl

# Ignore OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.vim/

# Ignore kubeconfig files
kubeconfig
kubeconfig.yaml
.kubeconfig

# Ignore environment files
.env
.env.local
.env.*.local

# Ignore logs
*.log
logs/

# Ignore backups
*.backup
*.bak
*.backup.*

# Ignore sensitive files
secrets/
certs/
keys/

# macOS
.AppleDouble
.AppleDB
.CFUserTextEncoding
